{
  "name": "@classroom/student-app",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.ts",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5174/login && tsc -p electron/tsconfig.json && electron .",
    "build": "tsc -p electron/tsconfig.json && vite build",
    "start": "electron ."
  },
  "dependencies": {
    "@classroom/shared": "1.0.0",
    "@nestjs/core": "11.1.19",
    "axios": "^1.6.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "electron": "^41.3.0",
    "typescript": "^5.4.5",
    "vite": "7",
    "wait-on": "^7.2.0"
  }
}