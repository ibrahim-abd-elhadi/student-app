NODE_ENV=development
HTTP_PORT=8080

DATABASE_URL=postgres://school:schoolpass@127.0.0.1:55432/school
REDIS_URL=redis://127.0.0.1:56379

# Generated by `openssl rand -base64 64` — replace before going to production.
JWT_SECRET=change-me-please-this-is-not-secure-only-for-local-dev-environments
JWT_ACCESS_TTL=900            # 15 minutes
JWT_REFRESH_TTL=604800        # 7 days

# CORS allow-list (comma-separated). Electron renderers use file:// origin
# which is reported as "null" — leave wildcard for dev only.
CORS_ORIGINS=*
