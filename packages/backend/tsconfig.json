{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",

    "rootDir": "..",

    "baseUrl": ".",

    "paths": {
      "@classroom/shared": ["../shared/src"],
      "@classroom/shared/*": ["../shared/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../shared/src/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}