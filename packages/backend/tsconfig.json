{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "skipLibCheck": true,
    "noEmitOnError": false,
    "types": ["node"],
    "paths": {
      "@classroom/shared": ["../shared/dist"],
      "@classroom/shared/*": ["../shared/dist/*"]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}